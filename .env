# Get free key at: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-paste-your-key-here

# ── Firebase ─────────────────────────────────────────────────
# Step 1: Set to true AFTER you put serviceAccountKey.json in backend/
# Step 2: Paste your Firebase DB URL below
USE_FIREBASE=false
FIREBASE_DB_URL=https://railsense-ai-default-rtdb.firebaseio.com
FIREBASE_CRED_PATH=serviceAccountKey.json

# ── Server ───────────────────────────────────────────────────
PORT=8000
